# Application Settings
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
WEBSOCKET_PORT=8002

# MySQL Database Configuration
# If you set this, it overrides the DB_* fields below
DATABASE_URL=mysql+pymysql://campus_ai_user:root@127.0.0.1:3306/campus_ai_db?charset=utf8mb4
DB_HOST=localhost
DB_PORT=3306
DB_USER=campus_ai_user
DB_PASSWORD=root
DB_NAME=campus_ai_db
DB_CHARSET=utf8mb4

# XAMPP MySQL (choose ONE connection method)
# Option A: UNIX socket (recommended for XAMPP). Uncomment and set the correct path.
# Typical XAMPP socket path on Linux:
MYSQL_UNIX_SOCKET=/opt/lampp/var/mysql/mysql.sock

# Option B: TCP to XAMPP on port 3306. Set DB_HOST=127.0.0.1 and make sure
# the system MySQL service is stopped so port 3306 is owned by XAMPP:
#   sudo systemctl stop mysql
#   sudo /opt/lampp/lampp startmysql

# Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_PRIMARY_MODEL=llama3.2:3b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=tinyllama:latest
# Security
SECRET_KEY=replace-with-a-secure-32char-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Add your external IP here for access from other devices
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://10.43.96.151:5173,http://10.43.96.151:3000


# Vector Database
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=./vector_store/campus_knowledge.faiss
FAISS_METADATA_PATH=./vector_store/metadata.json
RAG_TOP_K=15
RAG_SCORE_THRESHOLD=0.3
# L2 distance threshold for filtering irrelevant documents (lower = more strict)
# Typical range: 0.8 (very strict) to 1.5 (lenient). Default: 1.2
RAG_DISTANCE_THRESHOLD=1.2
MAX_CONTEXT_LENGTH=8192
MAX_MESSAGE_LENGTH=5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=../logs/backend.log

# Cache
ENABLE_RESPONSE_CACHE=True
CACHE_TTL=3600
